@using SocOps.Models

<div class="flex flex-col min-h-full bg-arcade-dark">
    <!-- Header -->
    <header class="arcade-header flex items-center justify-between p-3">
        <button
            @onclick="OnReset"
            class="text-neon-cyan text-sm px-3 py-2 rounded transition-all hover:text-hot-pink hover:text-shadow">
            ← BACK
        </button>
        <h1 class="font-bold text-neon-magenta arcade-title">SOC OPS</h1>
        <div class="w-16"></div>
    </header>

    <!-- Instructions -->
    <p class="text-center text-neon-cyan text-xs py-2 px-4">
        Tap a square when you find a match!
    </p>

    <!-- Bingo indicator -->
    @if (HasBingo)
    {
        <div class="bingo-alert text-center py-2 font-semibold text-sm animate-flash">
            🎉 BINGO! YOU GOT A LINE! 🎉
        </div>
    }

    <!-- Board -->
    <div class="flex-1 flex items-center justify-center p-3">
        <BingoBoard
            Board="@Board"
            WinningSquareIds="@WinningSquareIds"
            OnSquareClick="@OnSquareClick" />
    </div>
</div>

@code {
    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public bool HasBingo { get; set; }

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }

    [Parameter]
    public EventCallback OnReset { get; set; }
}
