<div class="flex flex-col items-center justify-center min-h-full p-6 bg-arcade-dark">
    <div class="text-center max-w-sm animate-arcade-bounce">
        <h1 class="arcade-title text-5xl font-bold mb-2">SOC OPS</h1>
        <p class="arcade-subtitle text-3xl mb-8">SOCIAL BINGO</p>

        <div class="arcade-box mb-8">
            <h2 class="text-neon-cyan font-semibold mb-3 text-sm">HOW TO PLAY</h2>
            <ul class="text-left text-neon-cyan text-xs space-y-2">
                <li>● Find people who match</li>
                <li>● Tap a square to mark</li>
                <li>● Get 5 in a row to WIN!</li>
            </ul>
        </div>

        <button
            @onclick="OnStart"
            class="w-full arcade-button py-3 px-6 text-sm">
            START GAME
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnStart { get; set; }
}
