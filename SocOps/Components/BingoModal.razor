<div class="arcade-modal-backdrop fixed inset-0 flex items-center justify-center p-4 z-50">
    <div class="arcade-modal rounded-xl p-6 max-w-xs w-full text-center animate-arcade-bounce">
        <div class="celebration-text mb-4">🎉</div>
        <h2 class="text-3xl font-bold text-neon-yellow mb-2 glow-yellow">BINGO!</h2>
        <p class="text-neon-cyan mb-6 text-sm">You completed a line!</p>

        <button
            @onclick="OnDismiss"
            class="w-full arcade-button py-3 px-6 text-sm">
            KEEP PLAYING
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnDismiss { get; set; }
}
